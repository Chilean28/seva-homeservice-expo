# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: EAS project ID for Expo push notifications (get via: cd packages/customer-app && npx eas init)
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# Stripe (test keys for sandbox). Publishable key can go in .env; secret key must go in Supabase only.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# In Supabase Dashboard → Edge Functions → Secrets, set: STRIPE_SECRET_KEY=sk_test_...
